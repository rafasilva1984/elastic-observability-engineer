# Copie este arquivo para .env antes de subir o ambiente:
#   cp .env.example .env

# Versão do Elastic Stack (Elasticsearch, Kibana, Elastic Agent).
# Consulte a versão mais recente em: https://www.elastic.co/downloads/elasticsearch
STACK_VERSION=9.4.3

# Senha do usuário "elastic" (superusuário do cluster).
ELASTIC_PASSWORD=onp-elastic-2026!

# Senha do usuário de sistema "kibana_system".
KIBANA_PASSWORD=onp-kibana-2026!

# Service token do Fleet Server. Gerado DEPOIS que o Elasticsearch estiver
# no ar, com o comando explicado no README (passo 6). Deixe em branco até lá.
FLEET_SERVER_SERVICE_TOKEN=

# Enrollment token do Agent Policy que você criar no Kibana para a
# Private Location de Synthetics (ver README, passo 7). Deixe em branco até lá.
SYNTHETICS_ENROLLMENT_TOKEN=
