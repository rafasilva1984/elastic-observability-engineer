# Copie este arquivo para .env antes de subir o ambiente:
#   cp .env.example .env

# Versão do Elastic Stack (Elasticsearch, Kibana, Elastic Agent).
# Consulte a versão mais recente em: https://www.elastic.co/downloads/elasticsearch
STACK_VERSION=9.4.3

# Senha do usuário "elastic" (superusuário do cluster).
ELASTIC_PASSWORD=onp-elastic-2026!

# Senha do usuário de sistema "kibana_system" (definida no passo 6.1 do README).
KIBANA_PASSWORD=onp-kibana-2026!

# Service token do Fleet Server (gerado no passo 6.2 do README). Deixe em branco até lá.
FLEET_SERVER_SERVICE_TOKEN=

# Enrollment token da Agent Policy de logs (criado no passo 7 do README). Deixe em branco até lá.
AGENT_ENROLLMENT_TOKEN=
