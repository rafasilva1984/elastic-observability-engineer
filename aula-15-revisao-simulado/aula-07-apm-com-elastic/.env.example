# Copie este arquivo para .env antes de subir:
#   cp .env.example .env

# Versão do Elastic Stack. Consulte: https://www.elastic.co/downloads/elasticsearch
STACK_VERSION=9.4.3

# Senha do usuário "elastic".
ELASTIC_PASSWORD=onp-elastic-2026!

# Senha do usuário de sistema "kibana_system" (passo 6.1 do README).
KIBANA_PASSWORD=onp-kibana-2026!

# Service token do Fleet Server (passo 6.2). Deixe em branco até lá.
FLEET_SERVER_SERVICE_TOKEN=

# Secret token do APM: você define este valor AQUI e usa o MESMO valor na
# configuração da integração Elastic APM no Kibana (passo 7). É ele que
# autoriza os agentes APM a enviarem dados ao APM Server.
APM_SECRET_TOKEN=onp-apm-2026!
