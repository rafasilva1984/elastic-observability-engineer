# Copie este arquivo para .env antes de subir o ambiente:
#   cp .env.example .env

# Versão do Elastic Stack (Elasticsearch e Kibana).
# Consulte a versão mais recente em: https://www.elastic.co/downloads/elasticsearch
STACK_VERSION=9.4.3

# Senha do usuário "elastic" (superusuário do cluster).
ELASTIC_PASSWORD=onp-elastic-2026!

# Senha do usuário de sistema "kibana_system", usado pelo Kibana para
# se conectar ao Elasticsearch. Definida manualmente após o cluster subir
# (ver README, passo 6.1).
KIBANA_PASSWORD=onp-kibana-2026!
