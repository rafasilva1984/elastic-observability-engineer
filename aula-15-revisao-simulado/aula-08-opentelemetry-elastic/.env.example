# Copie: cp .env.example .env

# Versão do Elastic Stack. Consulte: https://www.elastic.co/downloads/elasticsearch
STACK_VERSION=9.4.3
ELASTIC_PASSWORD=onp-elastic-2026!
KIBANA_PASSWORD=onp-kibana-2026!

# Service token do Fleet Server (passo 6.2 do README). Em branco até lá.
FLEET_SERVER_SERVICE_TOKEN=

# Secret token do APM: o MESMO valor configurado na integração Elastic APM
# no Kibana (passo 7). O Collector o envia como "Authorization: Bearer ...".
APM_SECRET_TOKEN=onp-apm-2026!
